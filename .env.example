# Together AI configuration for the chat interface.
# Replace with your Together API key and preferred model.
# This key is now used server-side and should not be injected into client bundles.
TOGETHER_API_KEY="YOUR_TOGETHER_API_KEY"
TOGETHER_MODEL="YOUR_TOGETHER_MODEL"

# Supabase configuration for storing registrations.
# This app expects the registrations table to be available in Supabase as registrations.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_REGISTRATIONS_TABLE="registrations"
VITE_SUPABASE_STORAGE_BUCKET="Registrations"

# Optional app URL used by the app runtime.
VITE_APP_URL="http://localhost:5000"

# Backend email configuration for contact submissions.
# Use a Google app password for EMAIL_PASS and do not commit real credentials.
EMAIL_USER="your-email@example.com"
EMAIL_PASS="your-google-app-password"
EMAIL_TO="recipient@example.com"

# Optional backend API base URL for development or separate API server.
# If this is blank, the front-end will submit to /api/contact on the current host.
VITE_API_URL="YOUR_BACKEND_API_URL"
